{
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/may-26", "destination": "/updates/may-26/index.html" },
    { "source": "/fonts/:file", "destination": "/public/fonts/:file" }
  ]
}
