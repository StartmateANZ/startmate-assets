{
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/OTSono-(.*).woff2",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/may-26", "destination": "/updates/may-26/index.html" },
    { "source": "/OTSono-Regular.woff2", "destination": "/public/OTSono-Regular.woff2" },
    { "source": "/OTSono-Medium.woff2", "destination": "/public/OTSono-Medium.woff2" }
  ]
}
